                  type: string
                  description: >-
                    Watermark text.


                    - Optional parameter

                    - If provided, a watermark will be added to the generated
                    video
                  examples:
                    - MyBrand
              required:
                - prompt
              x-apidog-orders:
                - prompt
                - imageUrls
                - model
                - generationType
                - aspect_ratio
                - seeds
